@model Microsoft.AspNetCore.Mvc.ProblemDetails
@{
    var code = Context.Response.StatusCode;
    var title = code switch
    {
        404 => "Page Not Found",
        403 => "Access Denied",
        500 => "Server Error",
        _ => "Something Went Wrong"
    };
    var message = code switch
    {
        404 => "The page you're looking for doesn't exist or has been moved.",
        403 => "You don't have permission to access this page.",
        500 => "An internal server error occurred. Please try again.",
        _ => "An unexpected error occurred."
    };
    ViewData["Title"] = title;
    ViewData["ActivePage"] = "";
}

<div style="display: flex; flex-direction: column; align-items: center;
            justify-content: center; min-height: 60vh; text-align: center;">

    <div style="font-size: 72px; font-weight: 800; font-family: var(--font-mono);
                color: var(--accent); opacity: 0.3; line-height: 1; margin-bottom: 16px;">
        @code
    </div>

    <h1 style="font-size: 24px; font-weight: 700; margin-bottom: 12px;">@title</h1>

    <p style="color: var(--text-faint); font-size: 14px; max-width: 400px; margin-bottom: 32px;">
        @message
    </p>

    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">
        Back to Dashboard
    </a>
</div>