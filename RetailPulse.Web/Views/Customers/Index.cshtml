@model IEnumerable<RetailPulse.Web.Models.Customer>

<div class="page-header">
    <div>
        <h1>Customers</h1>
        <p>Manage your customer base</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Add Customer
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card animate-in">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>City</th>
                    <th>Orders</th>
                    <th>Member Since</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td style="font-weight: 600;">@c.FullName</td>
                        <td style="color: var(--text-secondary);">@(c.Email ?? "—")</td>
                        <td style="color: var(--text-secondary);">@(c.Phone ?? "—")</td>
                        <td>@(c.City ?? "—")</td>
                        <td><span class="badge badge-blue">@c.SalesOrders.Count orders</span></td>
                        <td style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 12px;">
                            @c.CreatedAt.ToString("MMM d, yyyy")
                        </td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <a asp-action="Detail" asp-route-id="@c.CustomerId"
                                   class="btn btn-ghost" style="padding: 5px 10px; font-size: 12px;">View</a>
                                <a asp-action="Edit" asp-route-id="@c.CustomerId"
                                   class="btn btn-ghost" style="padding: 5px 10px; font-size: 12px;">Edit</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>