@model IEnumerable<RetailPulse.Web.Models.RestockLog>

<div class="page-header">
    <div>
        <h1>Restock History</h1>
        <p>All inventory restock events</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost">Back to Inventory</a>
</div>

<div class="card animate-in">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Product</th>
                    <th>Quantity Added</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td style="font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary);">
                            @log.RestockedAt.ToString("MMM d, yyyy h:mm tt")
                        </td>
                        <td style="font-weight: 600;">@log.Product.Name</td>
                        <td>
                            <span class="badge badge-green">+@log.Quantity units</span>
                        </td>
                        <td style="color: var(--text-secondary);">@(log.Notes ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>