@model RetailPulse.Web.Models.Product

<div class="page-header">
    <div>
        <h1>Restock Product</h1>
        <p>Add inventory for @Model.Name</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost">Back to Inventory</a>
</div>

<div class="grid-2" style="margin-bottom: 24px;">
    <div class="card animate-in">
        <div class="card-header">
            <span class="card-title">Current Stock Info</span>
        </div>
        <div style="display: flex; flex-direction: column; gap: 14px;">
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">PRODUCT</div>
                <div style="font-weight: 600; font-size: 15px;">@Model.Name</div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">SKU</div>
                <div style="font-family: var(--font-mono);">@Model.SKU</div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">SUPPLIER</div>
                <div>@Model.Supplier.Name</div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">CURRENT STOCK</div>
                <div style="font-size: 28px; font-weight: 700; font-family: var(--font-mono);
                            color: @(Model.StockQuantity <= Model.ReorderLevel ? "var(--red)" : "var(--green)");">
                    @Model.StockQuantity units
                </div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">REORDER LEVEL</div>
                <div style="font-family: var(--font-mono);">@Model.ReorderLevel units</div>
            </div>
        </div>
    </div>

    <div class="card animate-in">
        <div class="card-header">
            <span class="card-title">Add Stock</span>
        </div>
        <form asp-action="Restock" asp-route-id="@Model.ProductId" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="quantity">Quantity to Add</label>
                <input type="number" id="quantity" name="quantity" min="1" value="10"
                       style="font-size: 18px; font-weight: 700; font-family: var(--font-mono);" />
            </div>

            <div class="form-group">
                <label for="notes">Notes (optional)</label>
                <textarea id="notes" name="notes" rows="2"
                          placeholder="e.g. Regular restock from supplier"></textarea>
            </div>

            <div style="background: var(--bg-surface2); border-radius: var(--radius-sm);
                        padding: 12px 16px; margin-bottom: 20px;">
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 4px;">NEW STOCK AFTER RESTOCK</div>
                <div id="newStock" style="font-size: 22px; font-weight: 700;
                                          font-family: var(--font-mono); color: var(--green);">
                    @Model.StockQuantity units
                </div>
            </div>

            <div style="display: flex; gap: 12px;">
                <button type="submit" class="btn btn-primary">Confirm Restock</button>
                <a asp-action="Index" class="btn btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const current = @Model.StockQuantity;
        const qtyInput = document.getElementById('quantity');
        const newStockEl = document.getElementById('newStock');

        function update() {
            const qty = parseInt(qtyInput.value) || 0;
            newStockEl.textContent = (current + qty) + ' units';
        }

        qtyInput.addEventListener('input', update);
        update();
    </script>
}