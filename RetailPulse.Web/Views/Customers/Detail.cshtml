@model RetailPulse.Web.Models.Customer

<div class="page-header">
    <div>
        <h1>@Model.FullName</h1>
        <p>Customer profile and order history</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost">Back to Customers</a>
</div>

<div class="grid-2" style="margin-bottom: 24px;">
    <div class="card animate-in">
        <div class="card-header">
            <span class="card-title">Contact Details</span>
            <a asp-action="Edit" asp-route-id="@Model.CustomerId" style="font-size: 12px;">Edit</a>
        </div>
        <div style="display: flex; flex-direction: column; gap: 12px;">
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">EMAIL</div>
                <div>@(Model.Email ?? "—")</div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">PHONE</div>
                <div>@(Model.Phone ?? "—")</div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">CITY</div>
                <div>@(Model.City ?? "—")</div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">MEMBER SINCE</div>
                <div style="font-family: var(--font-mono); font-size: 12px;">@Model.CreatedAt.ToString("MMMM d, yyyy")</div>
            </div>
        </div>
    </div>

    <div class="card animate-in">
        <div class="card-header">
            <span class="card-title">Order Summary</span>
        </div>
        <div style="display: flex; flex-direction: column; gap: 12px;">
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">TOTAL ORDERS</div>
                <div style="font-size: 24px; font-weight: 700; font-family: var(--font-mono);">@Model.SalesOrders.Count</div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-faint); margin-bottom: 3px;">TOTAL SPENT</div>
                <div style="font-size: 24px; font-weight: 700; font-family: var(--font-mono);">
                    $@Model.SalesOrders.Sum(o => o.TotalAmount).ToString("N2")
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card animate-in">
    <div class="card-header">
        <span class="card-title">Order History</span>
    </div>
    @if (Model.SalesOrders.Any())
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.SalesOrders.OrderByDescending(x => x.OrderDate))
                    {
                        <tr>
                            <td style="font-family: var(--font-mono);">#@o.OrderId</td>
                            <td style="color: var(--text-secondary);">@o.OrderDate.ToString("MMM d, yyyy")</td>
                            <td style="font-family: var(--font-mono);">$@o.TotalAmount.ToString("N2")</td>
                            <td>
                                @switch (o.Status)
                                {
                                    case "Completed":
                                        <span class="badge badge-green">Completed</span>
                                        break;
                                    case "Pending":
                                        <span class="badge badge-yellow">Pending</span>
                                        break;
                                    case "Cancelled":
                                        <span class="badge badge-red">Cancelled</span>
                                        break;
                                    default:
                                        <span class="badge badge-blue">@o.Status</span>
                                        break;
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p style="color: var(--text-faint); font-size: 13px;">No orders yet.</p>
    }
</div>