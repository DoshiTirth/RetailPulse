@model RetailPulse.Web.Models.Customer

<div class="page-header">
    <div>
        <h1>Add Customer</h1>
        <p>Register a new customer</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost">Back to Customers</a>
</div>

<div class="card animate-in" style="max-width: 680px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="FirstName"></label>
                <input asp-for="FirstName" placeholder="e.g. Emma" />
                <span asp-validation-for="FirstName" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="LastName"></label>
                <input asp-for="LastName" placeholder="e.g. Thompson" />
                <span asp-validation-for="LastName" class="field-validation-error"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="email" placeholder="email@example.com" />
            </div>
            <div class="form-group">
                <label asp-for="Phone"></label>
                <input asp-for="Phone" placeholder="e.g. 416-555-0101" />
            </div>
        </div>

        <div class="form-group" style="max-width: 300px;">
            <label asp-for="City"></label>
            <input asp-for="City" placeholder="e.g. Toronto" />
        </div>

        <div style="display: flex; gap: 12px; margin-top: 8px;">
            <button type="submit" class="btn btn-primary">Save Customer</button>
            <a asp-action="Index" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>