@model RetailPulse.Web.Models.Product

<div class="page-header">
    <div>
        <h1>Add Product</h1>
        <p>Add a new product to the catalogue</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost">Back to Products</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card animate-in" style="max-width: 680px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="grid-2">
            <div class="form-group">
                <label>Product Name</label>
                <input type="text" name="Name" value="@Model.Name" placeholder="e.g. Wireless Headphones" required />
            </div>
            <div class="form-group">
                <label>SKU</label>
                <input type="text" name="SKU" value="@Model.SKU" placeholder="e.g. ELEC-005" required />
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label>Category</label>
                <select name="CategoryId" required>
                    <option value="">-- Select Category --</option>
                    @foreach (SelectListItem item in ViewBag.Categories)
                    {
                        if (item.Selected)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Supplier</label>
                <select name="SupplierId" required>
                    <option value="">-- Select Supplier --</option>
                    @foreach (SelectListItem item in ViewBag.Suppliers)
                    {
                        if (item.Selected)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label>Unit Price ($)</label>
                <input type="number" name="UnitPrice" value="@Model.UnitPrice" step="0.01" min="0" placeholder="0.00" required />
            </div>
            <div class="form-group">
                <label>Stock Quantity</label>
                <input type="number" name="StockQuantity" value="@Model.StockQuantity" min="0" placeholder="0" required />
            </div>
        </div>

        <div class="form-group" style="max-width: 200px;">
            <label>Reorder Level</label>
            <input type="number" name="ReorderLevel" value="@Model.ReorderLevel" min="0" placeholder="10" required />
        </div>

        <div style="display: flex; gap: 12px; margin-top: 8px;">
            <button type="submit" class="btn btn-primary">Save Product</button>
            <a asp-action="Index" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>