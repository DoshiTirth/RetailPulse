@model RetailPulse.Web.Models.Product

<div class="page-header">
    <div>
        <h1>Add Product</h1>
        <p>Add a new product to the catalogue</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost">Back to Products</a>
</div>

<div class="card animate-in" style="max-width: 680px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" placeholder="e.g. Wireless Headphones" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="SKU"></label>
                <input asp-for="SKU" placeholder="e.g. ELEC-005" />
                <span asp-validation-for="SKU" class="field-validation-error"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="CategoryId">Category</label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories">
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="SupplierId">Supplier</label>
                <select asp-for="SupplierId" asp-items="ViewBag.Suppliers">
                    <option value="">-- Select Supplier --</option>
                </select>
                <span asp-validation-for="SupplierId" class="field-validation-error"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="UnitPrice">Unit Price ($)</label>
                <input asp-for="UnitPrice" type="number" step="0.01" min="0" placeholder="0.00" />
                <span asp-validation-for="UnitPrice" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="StockQuantity">Stock Quantity</label>
                <input asp-for="StockQuantity" type="number" min="0" placeholder="0" />
                <span asp-validation-for="StockQuantity" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-group" style="max-width: 200px;">
            <label asp-for="ReorderLevel">Reorder Level</label>
            <input asp-for="ReorderLevel" type="number" min="0" placeholder="10" />
            <span asp-validation-for="ReorderLevel" class="field-validation-error"></span>
        </div>

        <div style="display: flex; gap: 12px; margin-top: 8px;">
            <button type="submit" class="btn btn-primary">Save Product</button>
            <a asp-action="Index" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>