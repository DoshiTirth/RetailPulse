<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RetailPulse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
</head>
<body>
    <div class="app-shell">

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="
                        width: 32px; height: 32px;
                        background: var(--accent);
                        border-radius: 8px;
                        display: flex; align-items: center; justify-content: center;
                        flex-shrink: 0;">
                        <svg width="18" height="18" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                            <text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle"
                                  font-family="'Segoe UI', system-ui, sans-serif"
                                  font-size="14" font-weight="700" fill="white">RP</text>
                        </svg>
                    </div>
                    <div>
                        <div class="logo-text">RetailPulse</div>
                        <div class="logo-sub">ERP Management System</div>
                    </div>
                </div>
            </div>

            <nav class="nav-section">
                <div class="nav-section-label">Overview</div>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7" />
                        <rect x="14" y="3" width="7" height="7" />
                        <rect x="3" y="14" width="7" height="7" />
                        <rect x="14" y="14" width="7" height="7" />
                    </svg>
                    Dashboard
                </a>
            </nav>

            <nav class="nav-section">
                <div class="nav-section-label">Catalogue</div>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Products" ? "active" : "")"
                   asp-controller="Products" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                    </svg>
                    Products
                </a>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Categories" ? "active" : "")"
                   asp-controller="Categories" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="8" y1="6" x2="21" y2="6" />
                        <line x1="8" y1="12" x2="21" y2="12" />
                        <line x1="8" y1="18" x2="21" y2="18" />
                        <line x1="3" y1="6" x2="3.01" y2="6" />
                        <line x1="3" y1="12" x2="3.01" y2="12" />
                        <line x1="3" y1="18" x2="3.01" y2="18" />
                    </svg>
                    Categories
                </a>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Suppliers" ? "active" : "")"
                   asp-controller="Suppliers" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                    Suppliers
                </a>
            </nav>

            <nav class="nav-section">
                <div class="nav-section-label">Sales</div>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Orders" ? "active" : "")"
                   asp-controller="Orders" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" y1="13" x2="8" y2="13" />
                        <line x1="16" y1="17" x2="8" y2="17" />
                        <polyline points="10 9 9 9 8 9" />
                    </svg>
                    Sales Orders
                </a>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Customers" ? "active" : "")"
                   asp-controller="Customers" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                    Customers
                </a>
            </nav>

            <nav class="nav-section">
                <div class="nav-section-label">Inventory</div>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Inventory" ? "active" : "")"
                   asp-controller="Inventory" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                    </svg>
                    Stock & Restock
                </a>
            </nav>

            <nav class="nav-section">
                <div class="nav-section-label">Analytics</div>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Reports" ? "active" : "")"
                   asp-controller="Reports" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="20" x2="18" y2="10" />
                        <line x1="12" y1="20" x2="12" y2="4" />
                        <line x1="6" y1="20" x2="6" y2="14" />
                    </svg>
                    Reports
                </a>
            </nav>
        </aside>

        <!-- Main Area -->
        <div class="main-area">
            <header class="topbar">
                <span class="topbar-title">@ViewData["Title"]</span>
                <div style="display: flex; align-items: center; gap: 16px;">
                    <span class="topbar-meta">@DateTime.Now.ToString("dddd, MMMM d yyyy")</span>

                    <!-- Dark/Light Toggle -->
                    <button id="theme-toggle" aria-label="Switch to light mode"
                            style="background: var(--bg-surface2); border: 1px solid var(--border);
                       border-radius: 20px; padding: 6px 12px; cursor: pointer;
                       display: flex; align-items: center; gap: 7px;
                       color: var(--text-secondary); font-size: 12px; font-weight: 600;
                       transition: background 0.2s, color 0.2s;">
                        <svg id="icon-dark" width="14" height="14" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                        </svg>
                        <svg id="icon-light" width="14" height="14" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2"
                             style="display:none;">
                            <circle cx="12" cy="12" r="5" />
                            <line x1="12" y1="1" x2="12" y2="3" />
                            <line x1="12" y1="21" x2="12" y2="23" />
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                            <line x1="1" y1="12" x2="3" y2="12" />
                            <line x1="21" y1="12" x2="23" y2="12" />
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                        </svg>
                        <span id="toggle-label">Light</span>
                    </button>
                </div>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>